# ==========================================
# 智识花园 - Git 忽略文件清单
# ==========================================

# ---------- 依赖 ----------
# 第三方包，安装时生成
node_modules/
.pnpm-store/

# ---------- 构建产物 ----------
# Nuxt 生成的中间/最终产物
.nuxt/
.output/
.data/
dist/

# ---------- 环境变量 ----------
# 真实环境变量（含密钥），不提交
.env
.env.*
# 允许提交 .env.example 作为模板
!.env.example

# ---------- 数据库 & 数据 ----------
# SQLite 数据库文件及 WAL 模式附属文件
data/
*.db
*.db-journal
*.db-wal
*.db-shm

# ---------- 用户内容 ----------
# 公开页面上传的图片（开发期暂存）
public/uploads/

# ---------- 日志 ----------
logs/
*.log
npm-debug.log*
pnpm-debug.log*

# ---------- 编辑器 / 操作系统 ----------
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ---------- 测试 / 覆盖率 ----------
coverage/
.vitest-cache/

# ---------- 杂项 ----------
.cache/
.tmp/
