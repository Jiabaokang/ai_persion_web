# 必填：服务器端密钥（生成方法：openssl rand -base64 32）
NUXT_SESSION_SECRET=change-me-32-bytes-base64

# 数据库（默认即可，部署时改路径）
NUXT_DB_PATH=./data/ai-personal.db

# 阿里云 OSS（任务 23 启用，本轮不用填）
NUXT_OSS_REGION=
NUXT_OSS_BUCKET=
NUXT_OSS_ACCESS_KEY_ID=
NUXT_OSS_ACCESS_KEY_SECRET=

# 站点元信息
NUXT_PUBLIC_SITE_NAME=智识花园
NUXT_PUBLIC_SITE_URL=https://example.com
NUXT_PUBLIC_AUTHOR_NAME=Jiabaokang
